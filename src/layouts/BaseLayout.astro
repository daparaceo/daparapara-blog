---
// src/layouts/BaseLayout.astro
// 모든 페이지에 공통으로 적용되는 기본 레이아웃
// 광고 스크립트, SEO 메타태그, 헤더/푸터가 여기에 포함됩니다

interface Props {
  title: string;
  description?: string;
  // OG 이미지 URL (SNS 공유 시 표시될 이미지)
  ogImage?: string;
  // 블로그 글 상세 페이지 여부 (article 타입 OG 태그 적용)
  isArticle?: boolean;
  // 글 발행일 (article 타입일 때 사용)
  publishedDate?: string;
}

const {
  title,
  description = '개인 블로그입니다. 다양한 주제의 글을 공유합니다.',
  ogImage = '/og-default.png',
  isArticle = false,
  publishedDate,
} = Astro.props;

// 사이트 기본 URL (astro.config.mjs의 site 값과 일치시켜야 함)
const siteUrl = 'https://daparaceo.github.io/GitpageBlog';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = `${title} | 블로그 이름`;  // ← 블로그 이름 변경
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- ===== SEO 기본 메타 태그 ===== -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- ===== Open Graph (SNS 공유용) ===== -->
  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:locale" content="ko_KR" />
  <meta property="og:site_name" content="블로그 이름" />  <!-- ← 블로그 이름 변경 -->
  {isArticle && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}

  <!-- ===== Twitter Card ===== -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />

  <!-- ===== 파비콘 (public/favicon.ico 또는 public/favicon.svg) ===== -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- ===== Google Fonts (Pretendard 대체용, 선택 사항) ===== -->
  <!-- <link rel="preconnect" href="https://fonts.googleapis.com" /> -->

  <!-- ==========================================================
    구글 애드센스 Auto Ads 스크립트
    애드센스 승인 후 아래 주석을 해제하고 ca-pub-XXXXXXXXXXXXXXXX를
    본인의 퍼블리셔 ID로 교체하세요.
  =========================================================== -->
  <!--
  <script async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"
    crossorigin="anonymous">
  </script>
  -->

  <!-- ==========================================================
    카카오 애드핏 스크립트
    애드핏 승인 후 아래 주석을 해제하세요.
    (단위 광고는 각 페이지/컴포넌트에서 별도 삽입)
  =========================================================== -->
  <!--
  <script async
    src="//t1.daumcdn.net/kas/static/ba.min.js">
  </script>
  -->
</head>

<body class="min-h-screen bg-white text-gray-800 flex flex-col">

  <!-- ===== 헤더 ===== -->
  <header class="border-b border-gray-200 sticky top-0 bg-white/90 backdrop-blur z-10">
    <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
      <!-- 블로그 로고/이름 -->
      <a href="/" class="text-xl font-bold text-gray-900 hover:text-brand-600 transition-colors">
        블로그 이름  <!-- ← 변경 -->
      </a>

      <!-- 네비게이션 메뉴 -->
      <ul class="flex gap-6 text-sm font-medium text-gray-600">
        <li><a href="/" class="hover:text-brand-600 transition-colors">홈</a></li>
        <li><a href="/tags" class="hover:text-brand-600 transition-colors">태그</a></li>
        <li><a href="/privacy" class="hover:text-brand-600 transition-colors">개인정보처리방침</a></li>
      </ul>
    </nav>
  </header>

  <!-- ===== 메인 콘텐츠 영역 ===== -->
  <main class="flex-grow max-w-3xl mx-auto w-full px-4 py-10">
    <!-- 페이지별 콘텐츠가 여기에 삽입됩니다 -->
    <slot />
  </main>

  <!-- ===== 푸터 ===== -->
  <footer class="border-t border-gray-200 mt-auto">
    <div class="max-w-3xl mx-auto px-4 py-6 text-center text-sm text-gray-500">
      <p>
        &copy; {new Date().getFullYear()} 블로그 이름.  <!-- ← 변경 -->
        All rights reserved.
      </p>
      <p class="mt-1">
        <a href="/privacy" class="hover:text-brand-600 underline">개인정보처리방침</a>
      </p>
    </div>
  </footer>

</body>
</html>

---
// src/layouts/BaseLayout.astro
// 공통 레이아웃 — 광고 스크립트, SEO 메타태그, 헤더/푸터

import { CATEGORIES } from '../content/config';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isArticle?: boolean;
  publishedDate?: string;
}

const {
  title,
  description = '생활정보, IT, 재테크 등 다양한 주제의 글을 공유하는 블로그입니다.',
  ogImage = '/og-default.png',
  isArticle = false,
  publishedDate,
} = Astro.props;

const SITE_NAME = 'daparapara';           // ← 블로그 이름 (변경 가능)
const siteUrl   = 'https://daparapara.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = `${title} | ${SITE_NAME}`;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type"        content={isArticle ? 'article' : 'website'} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:locale"      content="ko_KR" />
  <meta property="og:site_name"   content={SITE_NAME} />
  {isArticle && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- 네이버 서치어드바이저 소유권 확인 -->
  <meta name="naver-site-verification" content="6e02e575a21cec8481c63efac68fa4eb15350fba" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FBR7CMBCPX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-FBR7CMBCPX');
  </script>

  <!-- ===========================================================
    구글 애드센스 Auto Ads
    승인 후 ca-pub-XXXXXXXXXXXXXXXX를 본인 ID로 교체 후 주석 해제
  ============================================================ -->
  <!--
  <script async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"
    crossorigin="anonymous">
  </script>
  -->

  <!-- ===========================================================
    카카오 애드핏
    승인 후 주석 해제
  ============================================================ -->
  <!--
  <script async src="//t1.daumcdn.net/kas/static/ba.min.js"></script>
  -->
</head>

<body class="min-h-screen bg-white text-gray-800 flex flex-col">

  <!-- 헤더 -->
  <header class="border-b border-gray-200 sticky top-0 bg-white/90 backdrop-blur z-10">
    <div class="max-w-3xl mx-auto px-4">
      <!-- 상단 로고 + 주요 링크 -->
      <div class="flex items-center justify-between py-3">
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-brand-600 transition-colors">
          {SITE_NAME}
        </a>
        <ul class="flex gap-5 text-sm font-medium text-gray-600">
          <li><a href="/about"   class="hover:text-brand-600 transition-colors">소개</a></li>
          <li><a href="/privacy" class="hover:text-brand-600 transition-colors">개인정보처리방침</a></li>
        </ul>
      </div>

      <!-- 카테고리 네비게이션 -->
      <nav class="flex gap-4 pb-2 text-sm overflow-x-auto">
        {CATEGORIES.map(({ slug, label }) => (
          <a
            href={`/category/${slug}`}
            class="whitespace-nowrap text-gray-500 hover:text-brand-600 transition-colors pb-1 border-b-2 border-transparent hover:border-brand-400"
          >
            {label}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <!-- 메인 콘텐츠 -->
  <main class="flex-grow max-w-3xl mx-auto w-full px-4 py-10">
    <slot />
  </main>

  <!-- 푸터 -->
  <footer class="border-t border-gray-200 mt-auto">
    <div class="max-w-3xl mx-auto px-4 py-6 text-center text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} {SITE_NAME}. All rights reserved.</p>
      <p class="mt-1">
        <a href="/privacy" class="hover:text-brand-600 underline">개인정보처리방침</a>
        &nbsp;·&nbsp;
        <a href="/about" class="hover:text-brand-600 underline">소개</a>
      </p>
    </div>
  </footer>

  <!-- TTS: data-word 속성이 있는 요소 클릭 시 음성 재생 -->
  <script>
    document.addEventListener('click', function(e) {
      const item = e.target.closest('[data-word]');
      if (!item) return;

      const text = item.dataset.word;
      const lang = item.dataset.lang || 'en-US';

      item.style.opacity = '0.6';
      fetch(`https://tts-api-daparapara.vercel.app/tts?text=${encodeURIComponent(text)}&lang=${lang}`)
        .then(res => res.json())
        .then(data => {
          if (data.url) new Audio(data.url).play();
        })
        .catch(e => console.error('TTS 오류:', e))
        .finally(() => { item.style.opacity = '1'; });
    });
  </script>

</body>
</html>

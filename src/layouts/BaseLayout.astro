---
// src/layouts/BaseLayout.astro
// 공통 레이아웃 — 광고 스크립트, SEO 메타태그, 헤더/푸터

import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content/config';

// 글이 1개 이상 있는 카테고리만 헤더에 노출
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const activeCategories = CATEGORIES.filter(({ slug }) =>
  allPosts.some((p) => p.data.category === slug)
);

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isArticle?: boolean;
  publishedDate?: string;
}

const {
  title,
  description = '생활정보, IT, 재테크 등 다양한 주제의 글을 공유하는 블로그입니다.',
  ogImage = 'https://res.cloudinary.com/dtv8s65sa/image/upload/daparapara/blog/global/og-default.png',
  isArticle = false,
  publishedDate,
} = Astro.props;

const SITE_NAME = 'daparapara';           // ← 블로그 이름 (변경 가능)
const siteUrl   = Astro.site?.href.replace(/\/$/, '') ?? 'https://daparapara.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = `${title} | ${SITE_NAME}`;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type"        content={isArticle ? 'article' : 'website'} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />
  <meta property="og:locale"      content="ko_KR" />
  <meta property="og:site_name"   content={SITE_NAME} />
  {isArticle && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`} />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- 네이버 서치어드바이저 소유권 확인 -->
  <meta name="naver-site-verification" content="6e02e575a21cec8481c63efac68fa4eb15350fba" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FBR7CMBCPX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-FBR7CMBCPX');
  </script>

  <!-- 구글 애드센스 Auto Ads -->
  <script async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4251470918961546"
    crossorigin="anonymous">
  </script>

  <!-- 카카오 애드핏 -->
  <script async src="//t1.kakaocdn.net/kas/static/ba.min.js"></script>

</head>

<body class="min-h-screen bg-white text-gray-800 flex flex-col">

  <!-- 헤더 -->
  <header class="border-b border-gray-200 sticky top-0 bg-white/90 backdrop-blur z-10">
    <div class="max-w-3xl mx-auto px-4">
      <!-- 상단 로고 + 주요 링크 -->
      <div class="flex items-center justify-between py-3">
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-brand-600 transition-colors">
          {SITE_NAME}
        </a>
        <a href="/search" class="hover:text-brand-600 transition-colors text-gray-600" aria-label="검색">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
          </svg>
        </a>
      </div>

      <!-- 카테고리 네비게이션 -->
      <nav class="flex gap-4 pb-2 text-sm overflow-x-auto">
        {activeCategories.map(({ slug, label }) => (
          <a
            href={`/category/${slug}`}
            class="whitespace-nowrap text-gray-500 hover:text-brand-600 transition-colors pb-1 border-b-2 border-transparent hover:border-brand-400"
          >
            {label}
          </a>
        ))}
      </nav>
    </div>
  </header>

  <!-- 메인 콘텐츠 -->
  <main class="flex-grow max-w-3xl mx-auto w-full px-4 py-10">
    <slot />
  </main>

  <!-- 푸터 -->
  <footer class="border-t border-gray-200 mt-auto">
    <div class="max-w-3xl mx-auto px-4 py-6 text-center text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} {SITE_NAME}. All rights reserved.</p>
      <p class="mt-1">
        <a href="/privacy" class="hover:text-brand-600 underline">개인정보처리방침</a>
        &nbsp;·&nbsp;
        <a href="/about" class="hover:text-brand-600 underline">소개</a>
      </p>
    </div>
  </footer>

  <!-- TTS: data-word 속성이 있는 요소 클릭 시 음성 재생 -->
  <script>
    // 페이지 로드 시 모든 data-word 요소를 미리 fetch + Audio 객체 생성
    const ttsCache = new Map(); // text -> Audio

    function preloadTTS(text, lang) {
      if (ttsCache.has(text)) return;
      ttsCache.set(text, null); // pending 표시
      fetch(`https://api.daparapara.com/tts?text=${encodeURIComponent(text)}&lang=${lang}`)
        .then(res => res.json())
        .then(data => {
          if (data.url) {
            const audio = new Audio(data.url);
            audio.preload = 'auto';
            ttsCache.set(text, audio);
          }
        })
        .catch(() => { ttsCache.delete(text); });
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-word]').forEach(el => {
        preloadTTS(el.dataset.word, el.dataset.lang || 'en-US');
      });
    });

    document.addEventListener('click', function(e) {
      const item = e.target.closest('[data-word]');
      if (!item) return;

      const text = item.dataset.word;
      const lang = item.dataset.lang || 'en-US';
      const cached = ttsCache.get(text);

      if (cached) {
        cached.currentTime = 0;
        cached.play();
        return;
      }

      // 캐시 미스 시 fallback (preload 중이거나 실패한 경우)
      item.style.opacity = '0.6';
      fetch(`https://api.daparapara.com/tts?text=${encodeURIComponent(text)}&lang=${lang}`)
        .then(res => res.json())
        .then(data => {
          if (data.url) {
            const audio = new Audio(data.url);
            ttsCache.set(text, audio);
            audio.play();
          }
        })
        .catch(e => console.error('TTS 오류:', e))
        .finally(() => { item.style.opacity = '1'; });
    });
  </script>

</body>
</html>

---
// src/pages/tags/index.astro
// 전체 태그 목록 페이지

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);

// 태그별 글 수 집계
const tagCount: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}

// 글 수 내림차순으로 정렬
const sortedTags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="태그 목록" description="블로그 글 태그 목록입니다.">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">태그 목록</h1>

  {sortedTags.length === 0 ? (
    <p class="text-gray-500">등록된 태그가 없습니다.</p>
  ) : (
    <ul class="flex flex-wrap gap-3">
      {sortedTags.map(([tag, count]) => (
        <li>
          <a
            href={`/tags/${tag}`}
            class="inline-flex items-center gap-1 px-4 py-2 bg-gray-100 text-gray-700 rounded-full hover:bg-brand-100 hover:text-brand-700 transition-colors text-sm"
          >
            <span>#{tag}</span>
            <span class="text-xs text-gray-400">({count})</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

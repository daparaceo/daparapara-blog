---
// 카테고리별 글 목록 페이지 (/category/life-info 등)

import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../content/config';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);

  return CATEGORIES.map(({ slug, label }) => ({
    params: { cat: slug },
    props: {
      label,
      posts: allPosts
        .filter((p) => p.data.category === slug || (p.data.categories ?? []).includes(slug))
        .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()),
    },
  }));
}

const { cat } = Astro.params;
const { label, posts } = Astro.props;
---

<BaseLayout
  title={`${label} 글 목록`}
  description={`${label} 카테고리의 블로그 글 모음입니다.`}
>
  <div class="mb-8">
    <a href="/" class="text-sm text-brand-600 hover:underline mb-2 inline-block">← 전체 글</a>
    <h1 class="text-2xl font-bold text-gray-900">
      {label}
      <span class="text-base font-normal text-gray-400 ml-2">({posts.length}개)</span>
    </h1>
  </div>

  {posts.length === 0 ? (
    <p class="text-gray-500">아직 작성된 글이 없습니다.</p>
  ) : (
    <ul class="divide-y divide-gray-100">
      {posts.map((post) => (
        <li class="py-5 group">
          <a href={`/blog/${post.slug}`} class="block">
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex gap-2 mb-1">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="text-xs text-brand-600 font-medium">#{tag}</span>
                ))}
              </div>
            )}
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-brand-600 transition-colors mb-1">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-gray-600 text-sm line-clamp-2 mb-2">{post.data.description}</p>
            )}
            <time datetime={post.data.publishedAt.toISOString()} class="text-xs text-gray-400">
              {post.data.publishedAt.toLocaleDateString('ko-KR', {
                year: 'numeric', month: 'long', day: 'numeric',
              })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
